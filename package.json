{
  "name": "@dendelion/paper-ui",
  "version": "0.5.0",
  "description": "Natural-material React component library — paper, ink, canvas, and watercolor",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tailwind": {
      "types": "./tailwind.ts",
      "import": "./tailwind.ts",
      "require": "./tailwind.ts"
    },
    "./styles": {
      "types": "./src/styles/index.ts",
      "import": "./src/styles/index.ts",
      "require": "./src/styles/index.ts"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "tailwind.ts",
    "tailwind.config.js",
    "postcss.config.js",
    "src/styles",
    "src/globals.scss",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "build:showcase": "vite build --config vite.app.config.ts",
    "dev": "vite",
    "test": "echo 'No tests yet'",
    "check-types": "tsc --noEmit",
    "lint": "biome check ./src",
    "lint:fix": "biome check ./src --write",
    "ci": "pnpm run check-types && pnpm run build && pnpm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adooone/paper-ui.git"
  },
  "bugs": {
    "url": "https://github.com/adooone/paper-ui/issues"
  },
  "homepage": "https://github.com/adooone/paper-ui#readme",
  "keywords": [
    "react",
    "components",
    "ui",
    "paper",
    "natural",
    "organic",
    "tailwindcss",
    "design-system"
  ],
  "author": "Dendelion",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "framer-motion": "^12.40.0",
    "roughjs": "^4.6.6",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react-swc": "3.7.1",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.47",
    "sass-embedded": "^1.100.0",
    "tailwindcss": "3.4.14",
    "typescript": "^5.0.0",
    "vite": "5.4.9",
    "vite-plugin-dts": "^4.5.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome"
    ]
  }
}
